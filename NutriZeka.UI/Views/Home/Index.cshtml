@{
    ViewData["Title"] = "Dashboard";
}

<div class="content-wrapper">
    <div class="container-xxl flex-grow-1 container-p-y">

        <div class="row">
            @* 1. HOŞ GELDİN KARTI *@
            <div class="col-lg-8 mb-4 order-0">
                <div class="card">
                    <div class="d-flex align-items-end row">
                        <div class="col-sm-7">
                            <div class="card-body">
                                <h5 class="card-title text-primary">Hoş Geldin Süreyya! 🎉</h5>
                                <p class="mb-4">
                                    NutriZeka tıkır tıkır çalışıyor. Son 30 günde veritabanına <span class="fw-bold text-success">+@ViewBag.MonthlyNewProducts</span> yeni ürün eklendi. Sistem şu an optimize durumda.
                                </p>
                                <a href="/Product/Index" class="btn btn-sm btn-outline-primary">Ürünleri İncele</a>
                            </div>
                        </div>
                        <div class="col-sm-5 text-center text-sm-left">
                            <div class="card-body pb-0 px-0 px-md-4">
                                <img src="~/assets/img/illustrations/man-with-laptop-light.png"
                                     height="140"
                                     alt="NutriZeka Admin" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* 2. İSTATİSTİK KARTLARI (SAĞ ÜST) *@
            <div class="col-lg-4 col-md-4 order-1">
                <div class="row">
                    <div class="col-lg-6 col-md-12 col-6 mb-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <div class="card-title d-flex align-items-start justify-content-between">
                                    <div class="avatar flex-shrink-0">
                                        <span class="avatar-initial rounded bg-label-success"><i class="bx bx-box fs-4"></i></span>
                                    </div>
                                </div>
                                <span class="fw-semibold d-block mb-1">Toplam Ürün</span>
                                <h3 class="card-title mb-2">@ViewBag.TotalProduct</h3>
                                <small class="text-success fw-semibold"><i class="bx bx-check-circle"></i> Sistemde Aktif</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6 col-md-12 col-6 mb-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <div class="card-title d-flex align-items-start justify-content-between">
                                    <div class="avatar flex-shrink-0">
                                        <span class="avatar-initial rounded bg-label-info"><i class="bx bx-user fs-4"></i></span>
                                    </div>
                                </div>
                                <span>Kullanıcılar</span>
                                <h3 class="card-title text-nowrap mb-1">@ViewBag.TotalUser</h3>
                                <small class="text-info fw-semibold"><i class="bx bx-check-circle"></i> Sistemde Aktif</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            @* 3. VERİ AKIŞI GRAFİĞİ (SOL SÜTUN) *@
            <div class="col-12 col-lg-8 order-2 order-md-3 order-lg-2 mb-4">
                <div class="card h-100">
                    <div class="row row-bordered g-0 h-100">
                        <div class="col-md-12">
                            <h5 class="card-header m-0 me-2 pb-3">Son 30 Günlük Veri Akışı (Scraping)</h5>
                            <div id="productIncreaseChart" class="px-2" style="min-height: 315px;"></div>
                        </div>
                    </div>
                </div>
            </div>

            @* 4. GÜNÜN YILDIZI & KATEGORİ DAĞILIMI (SAĞ SÜTUN) *@
            <div class="col-12 col-md-8 col-lg-4 order-3 order-md-2 mb-4">

                @* EN ÇOK ARANAN ÜRÜN KARTI *@
                @if (ViewBag.MostScannedName != null)
                {
                    <div class="card mb-4 border-primary border" style="border-width: 1px !important;">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div class="card-title mb-0">
                                    <h5 class="m-0 me-2 fw-bold text-primary"><i class="bx bxs-award mb-1 me-1"></i> Günün Yıldızı</h5>
                                    <small class="text-muted">En Çok Aranan Ürün</small>
                                </div>
                            </div>
                            <div class="d-flex align-items-center bg-label-secondary p-3 rounded">
                                <div class="avatar avatar-xl me-3 bg-white p-1 rounded shadow-sm border">
                                    <img src="@ViewBag.MostScannedImage" alt="Top Product" style="object-fit: contain;" />
                                </div>
                                <div class="overflow-hidden">
                                    <h6 class="mb-1 text-dark fw-bold text-truncate" title="@ViewBag.MostScannedName">@ViewBag.MostScannedName</h6>
                                    <small class="text-muted d-block mb-2 text-truncate">@ViewBag.MostScannedBrand</small>
                                    <span class="badge bg-primary"><i class="bx bx-scan me-1"></i> @ViewBag.MostScannedCount Tarama</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @* GRAFİK VE DİNAMİK LİSTE *@
                <div class="card h-100">
                    <div class="card-header d-flex align-items-center justify-content-between pb-0">
                        <div class="card-title mb-0">
                            <h5 class="m-0 me-2">Dağılım Analizi</h5>
                            <small class="text-muted">Tüm Analiz Edilen Ürün Grupları</small>
                        </div>
                    </div>
                    <div class="card-body mt-4">

                        <div id="categoryDistributionChart"></div>

                        <ul class="p-0 m-0 mt-4">
                            @if (ViewBag.ChartLabels != null && ViewBag.ChartCounts != null)
                            {
                                var labels = (List<string>)ViewBag.ChartLabels;
                                var counts = (List<int>)ViewBag.ChartCounts;
                                var total = counts.Sum();
                                var colors = new[] { "primary", "success", "warning", "info", "danger", "secondary" };
                                var icons = new[] { "bx-cookie", "bx-coffee", "bx-baguette", "bx-apple", "bx-bowl-hot", "bx-cheese" };

                                // Tasarımı korumak için listeyi max 4 elemanla sınırlandırdık (Grafikte hepsi görünecek)
                                for (int i = 0; i < Math.Min(labels.Count, 4); i++)
                                {
                                    var percentage = total > 0 ? Math.Round((double)counts[i] / total * 100) : 0;
                                    <li class="d-flex mb-4 pb-1">
                                        <div class="avatar flex-shrink-0 me-3">
                                            <span class="avatar-initial rounded bg-label-@colors[i % colors.Length]">
                                                <i class="bx @icons[i % icons.Length]"></i>
                                            </span>
                                        </div>
                                        <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                                            <div class="me-2">
                                                <h6 class="mb-0">@labels[i]</h6>
                                            </div>
                                            <div class="user-progress">
                                                <small class="fw-semibold">@percentage%</small>
                                            </div>
                                        </div>
                                    </li>
                                }
                                if (labels.Count == 0)
                                {
                                    <li class="text-center text-muted mt-3"><small>Yeterli veri yok.</small></li>
                                }
                            }
                        </ul>

                    </div>
                </div>
            </div>
        </div>

    </div>
    <div class="content-backdrop fade"></div>
</div>

@section Scripts {
    <script src="~/assets/vendor/libs/apex-charts/apexcharts.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // --- 1. PASTA GRAFİĞİ (Tüm Kategoriler) ---
            let chartLabels = @Html.Raw(Json.Serialize(ViewBag.ChartLabels ?? new List<string>()));
            let chartCounts = @Html.Raw(Json.Serialize(ViewBag.ChartCounts ?? new List<int>()));

            if (chartCounts.length === 0) {
                chartLabels = ['Veri Bekleniyor'];
                chartCounts = [1];
            }

            const pieChartElement = document.querySelector('#categoryDistributionChart');
            const pieChartOptions = {
                chart: {
                    type: 'pie',
                    height: 300,
                    toolbar: { show: false }
                },
                series: chartCounts,
                labels: chartLabels,
                colors: ['#696cff', '#71dd37', '#ffab00', '#03c3ec', '#ff3e1d', '#8592a3', '#71dd37', '#696cff'], // Olası kategoriler için genişletilmiş palet
                dataLabels: {
                    enabled: true,
                    formatter: function (val) {
                        if (chartLabels[0] === 'Veri Bekleniyor') return "";
                        return Math.round(val) + "%"
                    }
                },
                legend: { show: false },
                stroke: { width: 2, colors: ['#fff'] }
            };

            if (typeof ApexCharts !== 'undefined' && pieChartElement !== null) {
                new ApexCharts(pieChartElement, pieChartOptions).render();
            }


            // --- 2. ÇİZGİ/ALAN GRAFİĞİ (Son 30 Günlük Veri Akışı) ---
            let lineLabels = @Html.Raw(Json.Serialize(ViewBag.LineLabels ?? new List<string>()));
            let lineData = @Html.Raw(Json.Serialize(ViewBag.LineData ?? new List<int>()));

            if (lineLabels.length === 0) {
                lineLabels = ['Pzt', 'Sal', 'Çar', 'Per', 'Cum', 'Cmt', 'Paz'];
                lineData = [0, 0, 0, 0, 0, 0, 0];
            }

            const lineChartEl = document.querySelector('#productIncreaseChart');
            const lineChartOptions = {
                chart: {
                    height: 315,
                    type: 'area',
                    parentHeightOffset: 0,
                    toolbar: { show: false }
                },
                dataLabels: { enabled: false },
                stroke: {
                    curve: 'smooth',
                    width: 3
                },
                series: [{
                    name: 'Eklenen Ürün',
                    data: lineData
                }],
                xaxis: {
                    categories: lineLabels,
                    axisBorder: { show: false },
                    axisTicks: { show: false },
                    labels: {
                        style: { colors: '#a1acb8', fontSize: '13px' }
                    }
                },
                yaxis: {
                    labels: {
                        style: { colors: '#a1acb8', fontSize: '13px' }
                    }
                },
                colors: ['#696cff'],
                fill: {
                    type: 'gradient',
                    gradient: {
                        shadeIntensity: 1,
                        opacityFrom: 0.4,
                        opacityTo: 0.05,
                        stops: [0, 90, 100]
                    }
                },
                grid: {
                    borderColor: '#eceef1',
                    strokeDashArray: 3,
                    padding: { top: -20, bottom: -8, left: -10, right: 8 }
                }
            };

            if (typeof ApexCharts !== 'undefined' && lineChartEl !== null) {
                new ApexCharts(lineChartEl, lineChartOptions).render();
            }


        });
    </script>
}