@model NutriZeka.UI.Dtos.UserDtos.UpdateUserDto
@{
    ViewData["Title"] = "Kullanıcı Güncelle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4">
        <span class="text-muted fw-light">Sistem / <a href="/User/Index" class="text-muted">Kullanıcılar</a> /</span> Kullanıcı Düzenle
    </h4>

    <div class="row">
        <div class="col-xl">
            <div class="card mb-4 shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center border-bottom mb-3">
                    <h5 class="mb-0 text-primary"><i class="bx bx-edit-alt me-2"></i>Profil Bilgilerini Güncelle</h5>
                    <small class="text-muted float-end">ID: @Model.Id.ToString().Substring(0, 8)...</small>
                </div>
                <div class="card-body">
                    <form asp-action="UpdateUser" method="post" enctype="multipart/form-data">
                        @* ID ve Mevcut Resim URL'sini gizli gönderiyoruz *@
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ProfileImageUrl" />

                        <div class="row">
                            <div class="col-md-6 border-end">
                                <div class="mb-3">
                                    <label class="form-label fw-bold" for="fullname">AD SOYAD</label>
                                    <div class="input-group input-group-merge">
                                        <span class="input-group-text"><i class="bx bx-user"></i></span>
                                        <input asp-for="FullName" type="text" class="form-control" id="fullname" placeholder="Ad Soyad" required />
                                    </div>
                                    <span asp-validation-for="FullName" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold" for="phone">TELEFON</label>
                                    <div class="input-group input-group-merge">
                                        <span class="input-group-text"><i class="bx bx-phone"></i></span>
                                        <input asp-for="PhoneNumber" type="text" class="form-control" id="phone" placeholder="05XX XXX XX XX" />
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">PROFİL RESMİ</label>
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@(string.IsNullOrEmpty(Model.ProfileImageUrl) ? "/assets/img/avatars/1.png" : Model.ProfileImageUrl)"
                                             alt="avatar" class="rounded" height="100" width="100" id="uploadedAvatar" style="object-fit: cover;" />
                                        <div class="button-wrapper">
                                            <input type="file" asp-for="ProfileImageFile" class="form-control" accept="image/png, image/jpeg" />
                                            <div class="text-muted small mt-1">JPG veya PNG. Maks 800K.</div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6 ps-md-4">
                                <label class="form-label fw-bold mb-3">DİYET VE FİLTRE TERCİHLERİ</label>

                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" asp-for="IsGlutenFree" id="glutenSwitch">
                                    <label class="form-check-label" for="glutenSwitch">Glutensiz Ürünleri Filtrele</label>
                                </div>

                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" asp-for="IsLactoseFree" id="lactoseSwitch">
                                    <label class="form-check-label" for="lactoseSwitch">Laktozsuz Ürünleri Filtrele</label>
                                </div>

                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" asp-for="IsPalmOilFree" id="palmSwitch">
                                    <label class="form-check-label" for="palmSwitch">Palm Yağı İçerenleri Filtrele</label>
                                </div>

                                <div class="alert alert-info mt-4" role="alert">
                                    <i class="bx bx-info-circle me-1"></i> Tercihler, ürün analizlerinde öncelikli olarak değerlendirilir.
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex justify-content-end gap-2">
                            <a href="/User/Index" class="btn btn-outline-secondary">Vazgeç</a>
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bx bx-check-double me-1"></i> Değişiklikleri Uygula
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}