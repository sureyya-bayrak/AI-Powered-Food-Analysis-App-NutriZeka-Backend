@model List<NutriZeka.UI.Dtos.UserDtos.ResultUserDto>
@{
    ViewData["Title"] = "Kullanıcı Listesi";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold py-3 mb-0">
            <span class="text-muted fw-light">Sistem /</span> Kullanıcılar
        </h4>
        <a href="/User/CreateUser" class="btn btn-primary">
            <span class="tf-icons bx bx-user-plus me-1"></span>Yeni Kullanıcı
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <h5 class="card-header">Kullanıcı Yönetim Paneli</h5>
        <div class="table-responsive text-nowrap">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Kullanıcı</th>
                        <th>İletişim</th>
                        <th>Profil Doluluğu</th>
                        <th>Diyet Filtreleri</th>
                        <th>Tür</th>
                        <th class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="table-border-bottom-0">
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar avatar-sm me-3">
                                        @if (!string.IsNullOrEmpty(user.ProfileImageUrl))
                                        {
                                            <img src="@user.ProfileImageUrl" alt="Avatar" class="rounded-circle" />
                                        }
                                        else
                                        {
                                            <span class="avatar-initial rounded-circle bg-label-primary">
                                                @(user.FullName?.Substring(0, 1).ToUpper() ?? "U")
                                            </span>
                                        }
                                    </div>
                                    <div class="d-flex flex-column">
                                        <span class="fw-medium">@user.FullName</span>
                                        <small class="text-muted">#@user.Id.ToString().Substring(0, 8)</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="small">
                                    <div class="mb-1"><i class="bx bx-envelope me-1"></i>@user.Email</div>
                                    <div><i class="bx bx-phone me-1"></i>@(user.PhoneNumber ?? "-")</div>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="progress w-100 me-2" style="height: 8px;">
                                        <div class="progress-bar @(user.ProfileCompletionRate < 50 ? "bg-danger" : "bg-success")"
                                             role="progressbar" style="width: @user.ProfileCompletionRate%"
                                             aria-valuenow="@user.ProfileCompletionRate" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <small>@user.ProfileCompletionRate%</small>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex flex-wrap gap-2">
                                    @if (user.IsGlutenFree)
                                    {
                                        <span class="badge bg-label-danger me-1">Glutensiz</span>
                                    }
                                    @if (user.IsLactoseFree)
                                    {
                                        <span class="badge bg-label-info me-1">Laktozsuz</span>
                                    }
                                    @if (user.IsPalmOilFree)
                                    {
                                        <span class="badge bg-label-dark me-1">Palm Yağsız</span>
                                    }
                                    @if (!user.IsGlutenFree && !user.IsLactoseFree && !user.IsPalmOilFree)
                                    {
                                        <span class="badge bg-label-secondary me-1">Filtre Yok</span>
                                    }
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-label-@(user.IsGoogleUser ? "danger" : "primary") me-1">
                                    @(user.IsGoogleUser ? "Google" : "Sistem")
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="dropdown">
                                    <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                                        <i class="bx bx-dots-vertical-rounded"></i>
                                    </button>
                                    <div class="dropdown-menu">
                                        <a class="dropdown-item" href="/User/UpdateUser/@user.Id"><i class="bx bx-edit-alt me-1"></i> Düzenle</a>
                                        <a class="dropdown-item text-danger" href="javascript:void(0);" onclick="openDeleteModal('@user.Id', '@user.FullName')">
                                            <i class="bx bx-trash me-1"></i> Sil
                                        </a>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-body text-center">
                <i class="bx bx-info-circle display-3 text-warning mb-3"></i>
                <h4 class="mb-2">Emin misiniz?</h4>
                <p class="text-muted">"<span id="deleteUserName" class="fw-bold"></span>" kullanıcısı silinecektir.</p>
                <div class="d-flex justify-content-center gap-2 mt-4">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">İptal</button>
                    <a id="confirmDeleteBtn" href="#" class="btn btn-danger">Evet, Sil</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openDeleteModal(id, name) {
            document.getElementById('deleteUserName').innerText = name;
            document.getElementById('confirmDeleteBtn').href = '/User/DeleteUser/' + id;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}