@model NutriZeka.WebUI.Dtos.ProductDtos.CreateProductDto
@{
    ViewData["Title"] = "Yeni Ürün Ekle";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Ürün Yönetimi /</span> Yeni Ürün Ekle</h4>

    <form asp-action="CreateProduct" method="post" id="createProductForm">
        <div class="row">
            <div class="col-12">
                <div class="nav-align-top mb-4">
                    <ul class="nav nav-tabs" role="tablist">
                        <li class="nav-item"><button type="button" class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-genel"><i class="bx bx-info-circle me-1"></i> Temel Bilgiler</button></li>
                        <li class="nav-item"><button type="button" class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-nutri"><i class="bx bx-stats me-1"></i> Besin Değerleri</button></li>
                        <li class="nav-item"><button type="button" class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-details"><i class="bx bx-detail me-1"></i> İçerik & Analiz</button></li>
                    </ul>
                    <div class="tab-content border shadow-none">

                        <div class="tab-pane fade show active" id="tab-genel" role="tabpanel">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label fw-bold text-primary">Barkod *</label>
                                    <input asp-for="Barcode" class="form-control" placeholder="869..." required />
                                    <span asp-validation-for="Barcode" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold text-primary">Ürün Adı (TR) *</label>
                                    <input asp-for="NameTr" class="form-control" required />
                                    <span asp-validation-for="NameTr" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Ürün Adı (EN) *</label>
                                    <input asp-for="NameEn" class="form-control" required />
                                    <span asp-validation-for="NameEn" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Marka *</label>
                                    <input asp-for="Brand" class="form-control" required />
                                    <span asp-validation-for="Brand" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Miktar (Örn: 250g) *</label>
                                    <input asp-for="Quantity" class="form-control" required />
                                    <span asp-validation-for="Quantity" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label text-info">Kategoriler (TR) *</label>
                                    <input asp-for="CategoriesTr" class="form-control" placeholder="Örn: İçecek, Gazlı İçecek" required />
                                    <span asp-validation-for="CategoriesTr" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Kategoriler (EN) *</label>
                                    <input asp-for="CategoriesEn" class="form-control" required />
                                    <span asp-validation-for="CategoriesEn" class="text-danger small"></span>
                                </div>
                                <div class="col-md-8">
                                    <label class="form-label">Görsel URL *</label>
                                    <input asp-for="ImageUrl" class="form-control" required />
                                    <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                                </div>
                                <hr />
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Nutri-Score *</label>
                                    <select asp-for="NutriScoreGrade" class="form-select" required>
                                        <option value="A">A</option>
                                        <option value="B">B</option>
                                        <option value="C">C</option>
                                        <option value="D">D</option>
                                        <option value="E">E</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Nova Group (1-4)</label>
                                    <input asp-for="NovaGroup" type="number" class="form-control" min="1" max="4" value="1" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Eco-Score *</label>
                                    <select asp-for="EcoScoreGrade" class="form-select" required>
                                        <option value="A">A</option>
                                        <option value="B">B</option>
                                        <option value="C">C</option>
                                        <option value="D">D</option>
                                        <option value="E">E</option>
                                        <option value="unknown">Unknown</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="tab-nutri" role="tabpanel">
                            <div class="alert alert-info py-2 small">Değerleri 100g üzerinden giriniz. Boş alanlar 0 kabul edilir.</div>
                            <div class="row g-3">
                                <div class="col-md-4"><label class="form-label">Enerji (kcal)</label><input asp-for="EnergyKcal" class="form-control" step="any" value="0" /></div>
                                <div class="col-md-4"><label class="form-label">Yağ (g)</label><input asp-for="Fat" class="form-control" step="any" value="0" /></div>
                                <div class="col-md-4"><label class="form-label">Karbonhidrat (g)</label><input asp-for="Carbohydrates" class="form-control" step="any" value="0" /></div>
                                <div class="col-md-4"><label class="form-label text-danger">Şeker (g)</label><input asp-for="Sugars" class="form-control" step="any" value="0" /></div>
                                <div class="col-md-4"><label class="form-label text-success">Protein (g)</label><input asp-for="Proteins" class="form-control" step="any" value="0" /></div>
                                <div class="col-md-4"><label class="form-label">Tuz (g)</label><input asp-for="Salt" class="form-control" step="any" value="0" /></div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="tab-details" role="tabpanel">
                            <div class="row g-3">
                                <div class="col-md-6"><label class="form-label">İçindekiler (TR) *</label><textarea asp-for="IngredientsTextTr" class="form-control" rows="3" required></textarea><span asp-validation-for="IngredientsTextTr" class="text-danger small"></span></div>
                                <div class="col-md-6"><label class="form-label">İçindekiler (EN) *</label><textarea asp-for="IngredientsTextEn" class="form-control" rows="3" required></textarea><span asp-validation-for="IngredientsTextEn" class="text-danger small"></span></div>
                                <div class="col-md-6"><label class="form-label">Alerjenler (TR) *</label><input asp-for="AllergensTr" class="form-control" required /><span asp-validation-for="AllergensTr" class="text-danger small"></span></div>
                                <div class="col-md-6"><label class="form-label">Alerjenler (EN) *</label><input asp-for="AllergensEn" class="form-control" required /><span asp-validation-for="AllergensEn" class="text-danger small"></span></div>
                                <hr />
                                <div class="col-md-12 d-flex gap-4">
                                    <div class="form-check form-switch"><input asp-for="ContainsGluten" class="form-check-input" type="checkbox"><label class="form-check-label">Gluten İçerir</label></div>
                                    <div class="form-check form-switch"><input asp-for="ContainsLactose" class="form-check-input" type="checkbox"><label class="form-check-label">Laktoz İçerir</label></div>
                                    <div class="form-check form-switch"><input asp-for="ContainsPalmOil" class="form-check-input" type="checkbox"><label class="form-check-label">Palm Yağı İçerir</label></div>
                                    <div class="form-check form-switch"><input asp-for="IsVerified" class="form-check-input" type="checkbox" checked><label class="form-check-label fw-bold text-success">Onaylı Ürün</label></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-light border-top p-3 text-end">
                        <a asp-action="Index" class="btn btn-label-secondary me-2">İptal</a>
                        <button type="submit" class="btn btn-primary shadow-sm"><i class="bx bx-save me-1"></i> Ürünü Oluştur</button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script>
        // UX Dokunuşu: Eğer görünmeyen sekmelerde hata varsa, butona basınca hatalı sekmeye gitsin
        $('#createProductForm').on('invalid-form.validate', function(event, validator) {
            if (validator.errorList.length) {
                var firstErrorElement = $(validator.errorList[0].element);
                var tabPane = firstErrorElement.closest('.tab-pane');
                var tabId = tabPane.attr('id');
                $('button[data-bs-target="#' + tabId + '"]').tab('show');
            }
        });
    </script>
}